# ===========================================
# AI Software Auditor — Root Environment
# Copy to .env and fill in values
# ===========================================

# PostgreSQL
POSTGRES_USER=auditor
POSTGRES_PASSWORD=auditor_secret
POSTGRES_DB=auditor_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://auditor:auditor_secret@localhost:5432/auditor_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=change-me-to-a-random-secret-key
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth (Phase 2 — Clerk)
# Get keys from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWT_ISSUER=https://your-app.clerk.accounts.dev

# Clerk frontend URLs (optional — defaults work for localhost)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# AI (Phase 6 — AI Auditor Layer)
# Optional: when set, audit narratives are generated by OpenAI.
# Without a key, the built-in rule-based auditor is used automatically.
# AI (Phase 6 — AI Auditor Layer)
# Gemini (recommended for Google AI Studio keys):
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_MODEL=gemini-2.0-flash
# OpenAI (alternative):
# OPENAI_API_KEY=sk-your-openai-key

# Billing (Phase 9 — Stripe)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# GITHUB_WEBHOOK_SECRET=your-github-webhook-secret
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_TEAM=price_...
# FRONTEND_URL=http://localhost:3000

# Email alerts (Phase 10 — optional)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_EMAIL=auditor@yourcompany.com

# Storage (Phase 3 — local uploads)
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=50

# S3 (Phase 9+ — optional)
